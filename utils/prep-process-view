#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# shellcheck disable=SC1090
source "$ROOT_DIR/compose/load-secrets.sh" >/dev/null

docker compose -p fscl -f "$ROOT_DIR/compose/process-stack.yaml" --profile infra up -d
docker compose -p fscl -f "$ROOT_DIR/compose/process-stack.yaml" --profile infra --profile app up -d outbox-publisher

bash "$ROOT_DIR/compose/load-process-api-env.sh" --write-debug-env "$ROOT_DIR/.vscode/process-api.debug.env"
