#!/bin/bash
# Publish ProjectCreatedEvent to NATS.
# Usage: ./create-project <project_id> <name> [description] [prefix] [separator] [block_length]
# Example: ./create-project dev-project "Dev Project" "Local dev environment" "=" "-" "4"

set -e

PROJECT_ID="${1:-dev-project}"
NAME="${2:-Dev Project}"
DESCRIPTION="${3:-}"
PREFIX="${4:-=}"
SEPARATOR="${5:--}"
BLOCK_LENGTH="${6:-4}"

# NATS server defaults
NATS_URL="${NATS_URL:-localhost:4222}"
NATS_SUBJECT="${NATS_SUBJECT:-events.project.created}"

# Generate UUIDs and timestamp
EVENT_ID=$(uuidgen | tr '[:upper:]' '[:lower:]')
OCCURRED_AT=$(date -u +"%Y-%m-%dT%H:%M:%S.000Z")

echo "[create-project] Publishing ProjectCreatedEvent for project: $PROJECT_ID"
echo "[create-project]   Name: $NAME"
echo "[create-project]   Event ID: $EVENT_ID"
echo "[create-project]   Format: prefix='$PREFIX' separator='$SEPARATOR' block_length=$BLOCK_LENGTH"
echo "[create-project]   NATS URL: $NATS_URL"
echo "[create-project]   Subject: $NATS_SUBJECT"

# Build description JSON field (null if empty)
if [ -n "$DESCRIPTION" ]; then
    DESC_JSON="\"$DESCRIPTION\""
else
    DESC_JSON="null"
fi

# Create JSON payload
read -r -d '' PAYLOAD <<EOF || true
{
  "event_id": "$EVENT_ID",
  "occurred_at": "$OCCURRED_AT",
  "project_id": "$PROJECT_ID",
  "name": "$NAME",
  "description": $DESC_JSON,
  "prefix": "$PREFIX",
  "separator": "$SEPARATOR",
  "block_length": $BLOCK_LENGTH
}
EOF

# Publish to NATS using nats CLI
if command -v nats &> /dev/null; then
    echo "$PAYLOAD" | nats pub --server="$NATS_URL" "$NATS_SUBJECT"
    echo "[create-project] Event published successfully"
else
    echo "[create-project] ERROR: 'nats' CLI not found."
    echo "[create-project] Payload to publish:"
    echo "$PAYLOAD"
    exit 1
fi

