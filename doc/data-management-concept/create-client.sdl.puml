@startuml
!pragma useVerticalIf on
floating note: CLIENT

start
:User enters Element; <<input>>
:User clicks SAVE; <<input>>
:POST CreateFunctionRequest(id, original_data); <<output>>
:show waiting state;
split
    :201 (id); <<output>>
    :Update client view (original_data);
split again
    :409 (id, SHADOW_DIFFERENT(shadow_data)); <<input>>
    :Show Content Decision Page;
    split
        :User clicks OVERWRITE; <<input>>
        :POST MergeRequest(id, MergeCmd::Client(original_data)); <<output>>
    split again
        :User clicks KEEP SERVER; <<input>>
        :POST MergeRequest(id, MergeCmd::Shadow(shadow_data)); <<output>>
    end split
    :show waiting state;
    split
        :200; <<input>>
        :Update client view (shadow_data);
    split again
        :4** or 500; <<input>>
        :Show Error Page;
        :User clicks OK; <<input>>
    end split
split again
    :409 (ID, SHADOW_IDENTICAL(shadow_data)); <<input>>
    :Show Cancel Option;
    split
        :User clicks CANCEL; <<input>>
    split again
        :Use clicks OK; <<input>>
        :POST MergeRequest(id, MergeCmd::Shadow(shadow_data)); <<output>>
        :show waiting state;
        split
        :200; <<input>>
        :Update client view (shadow_data);
        split again
            :other error; <<input>>
            :Show General Error Page;
            :User clicks OK; <<input>>
        end split
    end split
split again
    :409 (ID, VIEW_PREEXISTING(resource_data)); <<input>>
    :Show View Pre-existing Page;
    :User clicks OK; <<input>>
split again
    :other error; <<input>>
    :Show General Error Page;
    :User clicks OK; <<input>>
end split
:Refresh client view;
stop
@enduml