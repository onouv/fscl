# Copy to compose/secrets.local and set local secret values.
# This file is safe to commit; do not put real secrets here.

# Shared credentials (can be the same across views)
FSCL_DB_USER=fscl
FSCL_DB_PASSWORD=change-me
FSCL_NATS_USER=fscl
FSCL_NATS_PASSWORD=change-me

# Per-view database name
FSCL_DB_NAME=process_svc

# Optional host port overrides for parallel local stacks
# FSCL_PROCESS_DB_HOST_PORT=5432
# FSCL_PROCESS_API_HOST_PORT=3100
# FSCL_PROCESS_NATS_CLIENT_PORT=4222
# FSCL_PROCESS_NATS_MONITOR_PORT=8222

# Optional outbox tuning
# FSCL_OUTBOX_BATCH_SIZE=100
# FSCL_OUTBOX_FALLBACK_POLL_MS=1000
